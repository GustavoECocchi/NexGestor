{
  "name": "nexgestor-extension",
  "displayName": "NexGestor",
  "version": "0.1.0",
  "description": "Copiloto de diagnóstico inteligente para tráfego pago (Meta Ads / Google Ads).",
  "author": "NexGestor",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.268",
    "@types/node": "20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "^5.4.3"
  },
  "manifest": {
    "permissions": [
      "sidePanel"
    ],
    "host_permissions": [
      "https://*.facebook.com/*",
      "https://business.facebook.com/*",
      "http://localhost:8000/*"
    ],
    "action": {
      "default_title": "NexGestor — abrir painel"
    }
  }
}
